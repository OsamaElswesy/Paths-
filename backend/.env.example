# ── Application ──────────────────────────────────────────
APP_NAME=PATHS Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=paths_db
POSTGRES_USER=paths_user
POSTGRES_PASSWORD=paths_password
DATABASE_URL=postgresql+psycopg://paths_user:paths_password@postgres:5432/paths_db

# ── Apache AGE ──────────────────────────────────────────
AGE_GRAPH_NAME=paths_graph

# ── Qdrant ──────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_CV=candidate_cv_chunks
QDRANT_COLLECTION_VECTOR_SIZE=768

# ── Ollama ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Ingestion ───────────────────────────────────────────
UPLOAD_DIR=./uploads
CHUNK_SIZE=900
CHUNK_OVERLAP=120

# ── Authentication / JWT ────────────────────────────────
SECRET_KEY=CHANGE-ME-TO-A-RANDOM-SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
