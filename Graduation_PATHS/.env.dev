# Local dev override — used when running uvicorn directly (not in Docker).
# Postgres and Qdrant run as Docker containers mapped to localhost.

APP_NAME=PATHS Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
DEBUG=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=paths_db
POSTGRES_USER=paths_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg2://paths_user:change_me@localhost:5432/paths_db

AGE_GRAPH_NAME=paths_graph

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_CV=candidate_cv_chunks
QDRANT_COLLECTION_VECTOR_SIZE=768

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2:latest
OLLAMA_EMBED_MODEL=nomic-embed-text

UPLOAD_DIR=./uploads
CHUNK_SIZE=900
CHUNK_OVERLAP=120

SECRET_KEY=super-secret-dev-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
